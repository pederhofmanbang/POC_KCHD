  sys.system_hsaid, d.hsaid_vardenhet, d.sjukhusnamn, sys.system_hsaid, d.hsaid_region,
  CAST(d.median_vantetid AS DOUBLE), 'dagar', d.antal_genomforda, NULL, NULL,
  NULL AS strat_kon_man, NULL AS strat_kon_kvinna,
  NULL AS strat_age_under_50, NULL AS strat_age_50_64,
  NULL AS strat_age_65_74, NULL AS strat_age_75_84, NULL AS strat_age_85_plus,
  NULL AS strat_vt_0_30, NULL AS strat_vt_31_60, NULL AS strat_vt_61_90,
  NULL AS strat_vt_91_120, NULL AS strat_vt_121_180, NULL AS strat_vt_over_180,
