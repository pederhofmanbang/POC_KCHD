-- Per bokningssatt: andel_inom_90
SELECT
  sys.measure_url_vardgaranti, 'vardgaranti', 'proportion', 'complete', 'summary', 'andel_inom_90',
  CONCAT(CAST(d.ar AS VARCHAR),'-',LPAD(CAST(d.manad AS VARCHAR),2,'0'),'-01'), CAST(LASTDAYOFMONTH(CAST(CONCAT(CAST(d.ar AS VARCHAR),'-',LPAD(CAST(d.manad AS VARCHAR),2,'0'),'-01') AS DATE)) AS VARCHAR),
  sys.system_hsaid, d.hsaid_vardenhet, d.sjukhusnamn, sys.system_hsaid, d.hsaid_region,
  d.andel_inom_90, '%', d.antal_genomforda, d.namnare_vg, d.taljare_vg,
  NULL AS strat_kon_man, NULL AS strat_kon_kvinna,
