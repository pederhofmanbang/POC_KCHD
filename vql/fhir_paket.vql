-- ============================================================
-- FHIR-PAKET v3.1 (05_fhir/) — KOMPLETT, ALLA 16 KPI:er × ALLA DIMENSIONER
--
-- Skapade vyer:
--   ref_fhir_system         Alla system-URI:er (bytbara)
--   fhir_measure_report     Alla nyckeltal → MeasureReport-rader
--
-- Beroenden:
--   res_kpi_manad, res_kpi_per_yrke, res_kpi_per_kontaktform,
--   res_kpi_per_bokning, res_kpi_per_remittent, res_kpi_per_kommun
--
-- DESIGNBESLUT (se fhir_mappning_analys.md):
--   D1-D5: Measure-resurser, stratifiers, reporter, URI:er
--   D6: Per-dimensioner som stratifiers — alla 5 mått per dimension
--   D7: Medelväntetid som extra group
--   D8: Remiss→beslut som extra group
--
-- v3.1 ÄNDRINGAR (2026-03-28):
--   FIX 1: k.n_age_under_50 → k.n_age_lt50   (5 total-block)
--   FIX 2: k.n_age_85_plus  → k.n_age_85plus  (5 total-block)
--   FIX 3: d.kontaktform    → d.vardkontakttyp (5 per-kontaktform-block)
--   Alias (AS strat_age_under_50 etc.) är OFÖRÄNDRADE — Python/C# läser dessa.
-- ============================================================


CREATE OR REPLACE VIEW ref_fhir_system AS
SELECT
  'urn:oid:1.2.752.116.1.3.2.3.6'                        AS system_kva,
  'urn:oid:1.2.752.116.1.1.1'                            AS system_icd10se,
  'https://kchd.se/fhir/CodeSystem/skr-aktivitetskod'    AS system_skr_aktivitet,
  'https://kchd.se/fhir/CodeSystem/sjukhuskod'           AS system_sjukhuskod,
  'urn:oid:1.2.752.129.2.1.4.1'                          AS system_hsaid,
  'https://kchd.se/fhir/Measure/vantetid-vardgaranti'    AS measure_url_vardgaranti,
  'https://kchd.se/fhir/Measure/vantetid-median'         AS measure_url_median,
  'https://kchd.se/fhir/Measure/vantetid-patientresa'    AS measure_url_patientresa;


CREATE OR REPLACE VIEW fhir_measure_report AS
-- KPI 1-4: Andel inom 90d
SELECT
  sys.measure_url_vardgaranti AS measure_url, 'vardgaranti' AS measure_type,
  'proportion' AS scoring, 'complete' AS status, 'summary' AS report_type,
  'andel_inom_90' AS group_code,
  CONCAT(CAST(k.ar AS VARCHAR),'-',LPAD(CAST(k.manad AS VARCHAR),2,'0'),'-01') AS period_start, CAST(LASTDAYOFMONTH(CAST(CONCAT(CAST(k.ar AS VARCHAR),'-',LPAD(CAST(k.manad AS VARCHAR),2,'0'),'-01') AS DATE)) AS VARCHAR) AS period_end,
  sys.system_hsaid AS reporter_system, k.hsaid_vardenhet AS reporter_value, k.sjukhusnamn AS reporter_display,
  sys.system_hsaid AS subject_system, k.hsaid_region AS subject_value,
  k.andel_inom_90 AS measure_score, '%' AS measure_score_unit,
  k.antal_genomforda AS pop_initial, k.namnare_vg AS pop_denominator, k.taljare_vg AS pop_numerator,
  k.antal_man AS strat_kon_man, k.antal_kvinna AS strat_kon_kvinna,
  k.n_age_lt50 AS strat_age_under_50, k.n_age_50_64 AS strat_age_50_64,
  k.n_age_65_74 AS strat_age_65_74, k.n_age_75_84 AS strat_age_75_84, k.n_age_85plus AS strat_age_85_plus,
  k.n_0_30 AS strat_vt_0_30, k.n_31_60 AS strat_vt_31_60, k.n_61_90 AS strat_vt_61_90,
  k.n_91_120 AS strat_vt_91_120, k.n_121_180 AS strat_vt_121_180, k.n_over_180 AS strat_vt_over_180,
  CAST(NULL AS VARCHAR) AS dimension_type, CAST(NULL AS VARCHAR) AS dimension_value, CAST(NULL AS VARCHAR) AS dimension_display
FROM res_kpi_manad k CROSS JOIN ref_fhir_system sys
UNION ALL
-- KPI 5: Median
SELECT
  sys.measure_url_median AS measure_url, 'vantetid' AS measure_type,
  'continuous-variable' AS scoring, 'complete' AS status, 'summary' AS report_type,
  'median_vantetid' AS group_code,
  CONCAT(CAST(k.ar AS VARCHAR),'-',LPAD(CAST(k.manad AS VARCHAR),2,'0'),'-01') AS period_start, CAST(LASTDAYOFMONTH(CAST(CONCAT(CAST(k.ar AS VARCHAR),'-',LPAD(CAST(k.manad AS VARCHAR),2,'0'),'-01') AS DATE)) AS VARCHAR) AS period_end,
  sys.system_hsaid AS reporter_system, k.hsaid_vardenhet AS reporter_value, k.sjukhusnamn AS reporter_display,
  sys.system_hsaid AS subject_system, k.hsaid_region AS subject_value,
  CAST(k.median_vantetid AS DOUBLE) AS measure_score, 'dagar' AS measure_score_unit,
  k.antal_genomforda AS pop_initial, NULL AS pop_denominator, NULL AS pop_numerator,
  k.antal_man AS strat_kon_man, k.antal_kvinna AS strat_kon_kvinna,
  k.n_age_lt50 AS strat_age_under_50, k.n_age_50_64 AS strat_age_50_64,
  k.n_age_65_74 AS strat_age_65_74, k.n_age_75_84 AS strat_age_75_84, k.n_age_85plus AS strat_age_85_plus,
  k.n_0_30 AS strat_vt_0_30, k.n_31_60 AS strat_vt_31_60, k.n_61_90 AS strat_vt_61_90,
  k.n_91_120 AS strat_vt_91_120, k.n_121_180 AS strat_vt_121_180, k.n_over_180 AS strat_vt_over_180,
  CAST(NULL AS VARCHAR) AS dimension_type, CAST(NULL AS VARCHAR) AS dimension_value, CAST(NULL AS VARCHAR) AS dimension_display
FROM res_kpi_manad k CROSS JOIN ref_fhir_system sys
UNION ALL
-- KPI 10: Medel (D7)
SELECT
  sys.measure_url_median AS measure_url, 'vantetid' AS measure_type,
  'continuous-variable' AS scoring, 'complete' AS status, 'summary' AS report_type,
  'medel_vantetid' AS group_code,
  CONCAT(CAST(k.ar AS VARCHAR),'-',LPAD(CAST(k.manad AS VARCHAR),2,'0'),'-01') AS period_start, CAST(LASTDAYOFMONTH(CAST(CONCAT(CAST(k.ar AS VARCHAR),'-',LPAD(CAST(k.manad AS VARCHAR),2,'0'),'-01') AS DATE)) AS VARCHAR) AS period_end,
  sys.system_hsaid AS reporter_system, k.hsaid_vardenhet AS reporter_value, k.sjukhusnamn AS reporter_display,
  sys.system_hsaid AS subject_system, k.hsaid_region AS subject_value,
  CAST(k.medel_vantetid AS DOUBLE) AS measure_score, 'dagar' AS measure_score_unit,
  k.antal_genomforda AS pop_initial, NULL AS pop_denominator, NULL AS pop_numerator,
  k.antal_man AS strat_kon_man, k.antal_kvinna AS strat_kon_kvinna,
  k.n_age_lt50 AS strat_age_under_50, k.n_age_50_64 AS strat_age_50_64,
  k.n_age_65_74 AS strat_age_65_74, k.n_age_75_84 AS strat_age_75_84, k.n_age_85plus AS strat_age_85_plus,
  k.n_0_30 AS strat_vt_0_30, k.n_31_60 AS strat_vt_31_60, k.n_61_90 AS strat_vt_61_90,
  k.n_91_120 AS strat_vt_91_120, k.n_121_180 AS strat_vt_121_180, k.n_over_180 AS strat_vt_over_180,
  CAST(NULL AS VARCHAR) AS dimension_type, CAST(NULL AS VARCHAR) AS dimension_value, CAST(NULL AS VARCHAR) AS dimension_display
FROM res_kpi_manad k CROSS JOIN ref_fhir_system sys
UNION ALL
-- KPI 6: Patientresa
SELECT
  sys.measure_url_patientresa AS measure_url, 'patientresa' AS measure_type,
  'continuous-variable' AS scoring, 'complete' AS status, 'summary' AS report_type,
  'median_patientresa' AS group_code,
  CONCAT(CAST(k.ar AS VARCHAR),'-',LPAD(CAST(k.manad AS VARCHAR),2,'0'),'-01') AS period_start, CAST(LASTDAYOFMONTH(CAST(CONCAT(CAST(k.ar AS VARCHAR),'-',LPAD(CAST(k.manad AS VARCHAR),2,'0'),'-01') AS DATE)) AS VARCHAR) AS period_end,
  sys.system_hsaid AS reporter_system, k.hsaid_vardenhet AS reporter_value, k.sjukhusnamn AS reporter_display,
  sys.system_hsaid AS subject_system, k.hsaid_region AS subject_value,
  CAST(k.median_total_patientresa AS DOUBLE) AS measure_score, 'dagar' AS measure_score_unit,
  k.antal_genomforda AS pop_initial, NULL AS pop_denominator, NULL AS pop_numerator,
  k.antal_man AS strat_kon_man, k.antal_kvinna AS strat_kon_kvinna,
  k.n_age_lt50 AS strat_age_under_50, k.n_age_50_64 AS strat_age_50_64,
  k.n_age_65_74 AS strat_age_65_74, k.n_age_75_84 AS strat_age_75_84, k.n_age_85plus AS strat_age_85_plus,
  k.n_0_30 AS strat_vt_0_30, k.n_31_60 AS strat_vt_31_60, k.n_61_90 AS strat_vt_61_90,
  k.n_91_120 AS strat_vt_91_120, k.n_121_180 AS strat_vt_121_180, k.n_over_180 AS strat_vt_over_180,
  CAST(NULL AS VARCHAR) AS dimension_type, CAST(NULL AS VARCHAR) AS dimension_value, CAST(NULL AS VARCHAR) AS dimension_display
FROM res_kpi_manad k CROSS JOIN ref_fhir_system sys
UNION ALL
-- KPI 16: Remiss→beslut (D8)
SELECT
