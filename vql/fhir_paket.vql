  CAST(k.median_remiss_till_beslut AS DOUBLE) AS measure_score, 'dagar' AS measure_score_unit,
  k.antal_genomforda AS pop_initial, NULL AS pop_denominator, NULL AS pop_numerator,
  k.antal_man AS strat_kon_man, k.antal_kvinna AS strat_kon_kvinna,
  k.n_age_lt50 AS strat_age_under_50, k.n_age_50_64 AS strat_age_50_64,
  k.n_age_65_74 AS strat_age_65_74, k.n_age_75_84 AS strat_age_75_84, k.n_age_85plus AS strat_age_85_plus,
  k.n_0_30 AS strat_vt_0_30, k.n_31_60 AS strat_vt_31_60, k.n_61_90 AS strat_vt_61_90,
  k.n_91_120 AS strat_vt_91_120, k.n_121_180 AS strat_vt_121_180, k.n_over_180 AS strat_vt_over_180,
  CAST(NULL AS VARCHAR) AS dimension_type, CAST(NULL AS VARCHAR) AS dimension_value, CAST(NULL AS VARCHAR) AS dimension_display
FROM res_kpi_manad k CROSS JOIN ref_fhir_system sys
UNION ALL
-- Per yrkeskategori: andel_inom_90
SELECT
  sys.measure_url_vardgaranti, 'vardgaranti', 'proportion', 'complete', 'summary', 'andel_inom_90',
  CONCAT(CAST(d.ar AS VARCHAR),'-',LPAD(CAST(d.manad AS VARCHAR),2,'0'),'-01'), CAST(LASTDAYOFMONTH(CAST(CONCAT(CAST(d.ar AS VARCHAR),'-',LPAD(CAST(d.manad AS VARCHAR),2,'0'),'-01') AS DATE)) AS VARCHAR),
  sys.system_hsaid, d.hsaid_vardenhet, d.sjukhusnamn, sys.system_hsaid, d.hsaid_region,
  d.andel_inom_90, '%', d.antal_genomforda, d.namnare_vg, d.taljare_vg,
  NULL AS strat_kon_man, NULL AS strat_kon_kvinna,
  NULL AS strat_age_under_50, NULL AS strat_age_50_64,
  NULL AS strat_age_65_74, NULL AS strat_age_75_84, NULL AS strat_age_85_plus,
  NULL AS strat_vt_0_30, NULL AS strat_vt_31_60, NULL AS strat_vt_61_90,
  NULL AS strat_vt_91_120, NULL AS strat_vt_121_180, NULL AS strat_vt_over_180,
  'yrkeskategori', d.yrkeskategori, d.yrkeskategori
FROM res_kpi_per_yrke d CROSS JOIN ref_fhir_system sys
UNION ALL
-- Per yrkeskategori: median_vantetid
