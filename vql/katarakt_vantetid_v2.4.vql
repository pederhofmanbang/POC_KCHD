  COUNT(CASE WHEN vardgaranti='1' AND COALESCE(avvikelsekod,'')<>'1' THEN 1 END) AS namnare_vg,
  COUNT(CASE WHEN vardgaranti='1' AND COALESCE(avvikelsekod,'')<>'1' AND vantetid_dagar<=90 THEN 1 END) AS taljare_vg,
  CASE WHEN COUNT(CASE WHEN vardgaranti='1' AND COALESCE(avvikelsekod,'')<>'1' THEN 1 END) > 0
    THEN CAST(COUNT(CASE WHEN vardgaranti='1' AND COALESCE(avvikelsekod,'')<>'1' AND vantetid_dagar<=90 THEN 1 END) AS DOUBLE)
       / COUNT(CASE WHEN vardgaranti='1' AND COALESCE(avvikelsekod,'')<>'1' THEN 1 END)
    ELSE NULL END AS andel_inom_90,
  MEDIAN(total_patientresa_dagar) AS median_total_patientresa,
  MEDIAN(remiss_till_beslut_dagar) AS median_remiss_till_beslut
FROM calc_vantetid_genomford
GROUP BY op_ar, op_manad, hsaid_vardenhet, hsaid_region, regionkod, sjukhuskod, sjukhusnamn, remittenttyp, remittent_hsaid;

CREATE OR REPLACE VIEW res_kpi_per_kommun AS
SELECT
  op_ar AS ar, op_manad AS manad,
  hsaid_vardenhet, hsaid_region, regionkod, sjukhuskod, sjukhusnamn,
  lkf,
  COUNT(*) AS antal_genomforda,
  MEDIAN(vantetid_dagar) AS median_vantetid,
  AVG(CAST(vantetid_dagar AS DOUBLE)) AS medel_vantetid,
  COUNT(CASE WHEN vardgaranti='1' AND COALESCE(avvikelsekod,'')<>'1' THEN 1 END) AS namnare_vg,
  COUNT(CASE WHEN vardgaranti='1' AND COALESCE(avvikelsekod,'')<>'1' AND vantetid_dagar<=90 THEN 1 END) AS taljare_vg,
  CASE WHEN COUNT(CASE WHEN vardgaranti='1' AND COALESCE(avvikelsekod,'')<>'1' THEN 1 END) > 0
    THEN CAST(COUNT(CASE WHEN vardgaranti='1' AND COALESCE(avvikelsekod,'')<>'1' AND vantetid_dagar<=90 THEN 1 END) AS DOUBLE)
       / COUNT(CASE WHEN vardgaranti='1' AND COALESCE(avvikelsekod,'')<>'1' THEN 1 END)
    ELSE NULL END AS andel_inom_90,
  MEDIAN(total_patientresa_dagar) AS median_total_patientresa,
  MEDIAN(remiss_till_beslut_dagar) AS median_remiss_till_beslut
FROM calc_vantetid_genomford
GROUP BY op_ar, op_manad, hsaid_vardenhet, hsaid_region, regionkod, sjukhuskod, sjukhusnamn, lkf;


-- ──────────────────────────────────────────────
-- 03c: Detaljvyer (ÄNDRAD: is_hemregion tillagt)
-- ──────────────────────────────────────────────

CREATE OR REPLACE VIEW res_genomford_detalj AS
SELECT
  vardkontakt_id, patient_id, kon, fodelsear, aldersgrupp,
  regionkod, sjukhuskod, sjukhusnamn, hsaid_vardenhet,
  mvo_kod, kva_kod, aktivitetskod,
  yrkeskategori, bokningssatt, vardkontakttyp,
  vardgaranti, avvikelsekod,
  remittenttyp, remittent_hsaid,
  remiss_datum, ankomst_datum, beslut_datum, start_datum,
  medicinskt_maldatum, lkf, hsaid_listning, matperiod,
  vantetid_dagar, vantetid_intervall, uppfyller_vg,
  total_patientresa_dagar, remiss_till_beslut_dagar,
  is_hemregion,                                          -- NYTT i v2.4
  op_ar, op_manad
FROM calc_vantetid_genomford;

CREATE OR REPLACE VIEW res_vantande_detalj AS
SELECT
  vardkontakt_id, patient_id, kon, fodelsear,
  regionkod, sjukhuskod, sjukhusnamn, hsaid_vardenhet,
  mvo_kod, kva_kod, aktivitetskod,
  yrkeskategori, vardgaranti, avvikelsekod,
  remittenttyp, remittent_hsaid,
  remiss_datum, beslut_datum, medicinskt_maldatum,
  lkf, hsaid_listning, matperiod,
  vantetid_dagar, vantetid_intervall,
  rapportdatum, vantestatus, bryter_vg
FROM calc_vantande;



-- ============================================================
-- KÖRORDNING:
--   1. ref_kva_katarakt
--   2. ref_avvikelsekoder
--   3. ref_filter_region        ← ⚠️ ÄNDRA lanskod per region
--   4. src_genomford             ← ⚠️ ÄNDRA kolumner + tabell
--   5. src_vantande              ← ⚠️ ÄNDRA kolumner + tabell
--   6. calc_vantetid_genomford
--   7. calc_vantande
--   8. res_kpi_manad
--   9. res_kpi_per_yrke + _kontaktform + _bokning + _remittent + _kommun
--  10. res_genomford_detalj + res_vantande_detalj
--  11. verif_jamforelse
--  12. dq_rapport_data
--
-- VERIFIERING:
--   SELECT * FROM dq_rapport_data;
--   → Alla DQ0-DQ3 och DQ5 ska vara OK
--   → DQ4 visar ifyllnadsgrad (INFO)
--   → DQ6 visar rimlighet per sjukhus
--
--   SELECT * FROM verif_jamforelse ORDER BY sjukhus, kpi;
--   → Jämför mot vantetider.se per sjukhus
--
--   Om siffror avviker: prova att lägga till
--   WHERE is_hemregion = 1 i res_kpi_manad
--   för att se om utomläningar förklarar skillnaden.
-- ============================================================
